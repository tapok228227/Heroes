@startuml

left to right direction

actor Player

rectangle "Hero Game" {
    usecase "Create Hero" as UC1
    usecase "Equip Weapon" as UC2
    usecase "Attack Enemy" as UC3
    usecase "Receive Damage" as UC4
}

Player --> UC1
Player --> UC2
Player --> UC3

UC3 ..> UC4 : <<include>>
UC2 ..> UC3 : <<extend>>

@enduml